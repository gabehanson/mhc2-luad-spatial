# ---------------------------------------------------------------
# ceiba / spatial-methods-paper .gitignore
# ---------------------------------------------------------------
# ---- Data (never commit raw or processed data) ----
data/*.h5ad
*.h5
*.loom
*.zarr
*.csv
*.tsv
*.parquet
*.feather
claude_CONTEXT.md
**/claude_CONTEXT.md
**/cosmx_context.md

# Exception: small reference files in data/ that should be committed
!data/paths_config.yml
!data/cosmx_gene_probe_details.csv
!data/cosmx_pathway_annotations.csv
!data/cosmx_genes_not_in_salcher_reference.csv
!data/cbioportal_query.md

# ---- Outputs (regeneratable — commit selectively) ----
# Uncomment the lines below if you want to exclude outputs entirely.
# By default we track outputs/ so figures are versioned with the paper.
# outputs/
outputs/tables/figure3/*_single_cell.csv

# ---- Jupyter ----
.ipynb_checkpoints/
*/.ipynb_checkpoints/
# nbstripout handles output stripping — but this catches any stragglers
*.ipynb_checkpoints

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# ---- Virtual environments ----
.env
.venv
env/
venv/
*.conda
.conda/

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDEs ----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---- Secrets / config overrides ----
*.env
secrets.yml
local_config.yml           # use this for machine-specific path overrides
                           # paths_config.yml is committed; local_config.yml is not

# ---- Large files / temp ----
*.log
*.tmp
*.bak
*.swp
~$*
*.pdf
